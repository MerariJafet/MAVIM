# MAVIM DevRel Intelligence System — Environment Variables
# Copiar a .env y completar con tus credenciales

# ── Reddit API (https://www.reddit.com/prefs/apps → "script" app) ──
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=mavim-devrel/1.0 by u/your_username

# ── Stack Exchange API (https://stackapps.com/apps/oauth/register) ──
STACKOVERFLOW_KEY=your_api_key

# ── GitHub API (https://github.com/settings/tokens) ──
# Permisos mínimos: public_repo, read:discussion
GITHUB_TOKEN=your_token

# ── Notificaciones Email (IMAP/SMTP) ──
NOTIFY_EMAIL=tu@email.com
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=tu@gmail.com
NOTIFY_SMTP_PASS=tu_app_password
NOTIFY_IMAP_HOST=imap.gmail.com

# ── MAVIM Config ──
MAVIM_REPO_URL=https://github.com/MerariJafet/MAVIM
MAVIM_DOCS_BASE=https://github.com/MerariJafet/MAVIM/blob/main
REPORT_OUTPUT_DIR=./data/reports
SCAN_INTERVAL_MINUTES=60
